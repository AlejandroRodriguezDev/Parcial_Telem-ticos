$TTL    604800
@       IN      SOA     maestro.empresa.local. admin.empresa.local. (
                              2026030201 ; Serial
                              604800     ; Refresh
                              86400      ; Retry
                              2419200    ; Expire
                              604800 )   ; Negative Cache TTL
; Name servers
@       IN      NS      maestro.empresa.local.
@       IN      NS      esclavo.empresa.local.

; Registros PTR (Resolución inversa)
3       IN      PTR     maestro.empresa.local.
4       IN      PTR     esclavo.empresa.local.
2       IN      PTR     cliente.empresa.local.
