zone "empresa.local" {
    type master;
    file "/etc/bind/db.empresa.local";
    allow-transfer { 192.168.50.4; }; // Solo el esclavo puede pedir la zona
    notify yes; // Habilita NOTIFY
};

zone "50.168.192.in-addr.arpa" {
    type master;
    file "/etc/bind/db.192.168.50";
    allow-transfer { 192.168.50.4; };
    notify yes;
};
zone "parcial.alejo.com" {
    type master;
    file "/etc/bind/db.parcial";
};
